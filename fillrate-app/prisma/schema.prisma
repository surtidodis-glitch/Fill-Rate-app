// Esquema de base de datos — Fill Rate App
// Cada fila representa un registro de la hoja BASE_MAESTRA

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model FillRateRecord {
  id             Int      @id @default(autoincrement())
  semana         String // ej. "W27"
  pais           String
  tienda         String
  departamento   String
  categoria      String
  subcategoria   String
  surtido        Int
  entrega        Int
  fillRate       Float    @map("fill_rate")
  clasificacion  String
  // Trazabilidad de la carga
  loadId         Int
  load           DataLoad @relation(fields: [loadId], references: [id])
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([semana])
  @@index([pais])
  @@index([tienda])
  @@index([departamento])
  @@map("fillrate_records")
}

// Registro de cada archivo Excel cargado — permite auditar y revertir cargas
model DataLoad {
  id           Int              @id @default(autoincrement())
  fileName     String           @map("file_name")
  rowCount     Int              @map("row_count")
  status       String           @default("procesando") // procesando | completado | error
  errorLog     String?          @map("error_log")
  uploadedAt   DateTime         @default(now()) @map("uploaded_at")
  records      FillRateRecord[]

  @@map("data_loads")
}
